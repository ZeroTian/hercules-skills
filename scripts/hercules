#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(cd -- "$SCRIPT_DIR/.." && pwd)
BOOTSTRAP_SCRIPT="skills/hercules-agent-capability-preflight/scripts/bootstrap-hercules-workflow.sh"
INSTALL_SCRIPT="scripts/install-hercules.sh"
VALIDATOR="scripts/validate-skill-pack.py"
EXPECTED_SKILL_COUNT=25

cd "$REPO_ROOT"

usage() {
  cat <<'USAGE'
Hercules skill-pack helper

Usage:
  scripts/hercules <command> [args]

Setup / health:
  setup [--full|--minimal|--dry-run] [--yes] [installer options]
      Guided/productized install entry. Delegates to scripts/install-hercules.sh.
      --full     recommended full setup, including optional Claude plugins
      --minimal  non-interactive minimal setup, no Claude plugin mutation
      --dry-run  preview only; no installs, clones, pulls, registry writes, or symlink changes

  doctor [--fix] [--full] [--json] [--strict]
      Dashboard-style environment check. By default it is read-only.
      --fix      repair minimal dependencies by running setup --minimal
      --full     with --fix, also align optional Claude plugin dependencies
      --json     emit machine-readable summary
      --strict   return nonzero on warnings, fixable items, or blockers

Existing commands:
  validate            Run repo validation, whitespace diff check, and bootstrap script syntax check.
  bootstrap --check   Run Hercules bootstrap/dependency doctor in audit-only mode.
  status              Show concise repo status, latest commit, runtime skill count, and validator summary.
  package             Check staged package readiness without committing or pushing.
  help                Show this help.

Notes:
  - This helper never pushes.
  - package never commits; it only verifies the staged package.
  - doctor without --fix is read-only.
USAGE
}

section() {
  printf '\n==> %s\n' "$*"
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

runtime_skill_count() {
  find skills -mindepth 2 -maxdepth 2 -name SKILL.md -type f | wc -l | tr -d ' '
}

run_validate() {
  section "validator"
  python3 "$VALIDATOR"

  section "git diff --check"
  git diff --check

  section "bootstrap script syntax"
  bash -n "$BOOTSTRAP_SCRIPT"
}

run_bootstrap_check() {
  if [ "${1:-}" != "--check" ] || [ "$#" -ne 1 ]; then
    printf 'Usage: scripts/hercules bootstrap --check\n' >&2
    return 2
  fi
  section "bootstrap audit-only"
  HERCULES_CHECK_ONLY=1 bash "$BOOTSTRAP_SCRIPT"
}

run_setup() {
  if [ "$#" -eq 0 ]; then
    "$INSTALL_SCRIPT"
    return $?
  fi
  "$INSTALL_SCRIPT" "$@"
}

run_status() {
  section "repository"
  printf 'root: %s\n' "$REPO_ROOT"
  printf 'branch: '
  git branch --show-current
  printf 'latest_commit: '
  git log -1 --oneline

  section "worktree"
  if git status --short -uall | grep -q .; then
    git status --short -uall
  else
    printf 'clean\n'
  fi

  section "skills"
  printf 'runtime_skill_count: %s\n' "$(runtime_skill_count)"

  section "validator summary"
  python3 "$VALIDATOR"
}

privacy_scan_staged() {
  section "staged privacy scan"
  if git diff --cached --name-only | grep -Ei '(^|/)(\.env|.*secret.*|.*token.*|.*credential.*|id_rsa|id_ed25519|config\.toml)$'; then
    printf 'SENSITIVE_FILENAMES_FOUND\n' >&2
    return 2
  fi
  printf 'filename scan ok\n'

  # Build the regex from fragments so this helper's own source does not
  # trigger the staged-diff secret scan when the helper is modified.
  local github_token_pat='ghp_''[A-Za-z0-9_]{20,}'
  local openai_token_pat='sk-''[A-Za-z0-9]{20,}'
  local aws_key_pat='AKIA''[0-9A-Z]{16}'
  local private_key_pat='BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY'
  local api_key_pat='ANTHROPIC_''API_KEY|OPENAI_''API_KEY|SUDO_''PASSWORD'
  local secret_regex="(${github_token_pat}|${openai_token_pat}|${aws_key_pat}|${private_key_pat}|${api_key_pat})"
  local hits
  hits=$(git diff --cached | grep -Eai "$secret_regex" | sed -n '1,20p' || true)
  if [ -n "$hits" ]; then
    printf 'SECRET_PATTERN_FOUND\n' >&2
    printf '%s\n' "$hits" >&2
    return 3
  fi
  printf 'content scan ok\n'
}

run_package() {
  section "package readiness (no commit / no push)"
  printf 'This command verifies the staged package only. It does not commit or push.\n'
  run_validate

  section "git diff --cached --check"
  git diff --cached --check

  section "staged paths"
  if git diff --cached --name-only | grep -q .; then
    git diff --cached --name-only
  else
    printf 'no staged paths\n'
  fi

  privacy_scan_staged
}

# Doctor state. Status classes:
#   ok       satisfied
#   warn     usable but not ideal
#   fixable  can be repaired by doctor --fix
#   blocked  requires user action for a core local setup or validation failure
DOCTOR_JSON=0
DOCTOR_STRICT=0
DOCTOR_OK=0
DOCTOR_WARN=0
DOCTOR_FIXABLE=0
DOCTOR_BLOCKED=0
DOCTOR_CHECKS=()

json_escape() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

record_check() {
  local status="$1" name="$2" message="${3:-}"
  case "$status" in
    ok) DOCTOR_OK=$((DOCTOR_OK + 1)) ;;
    warn) DOCTOR_WARN=$((DOCTOR_WARN + 1)) ;;
    fixable) DOCTOR_FIXABLE=$((DOCTOR_FIXABLE + 1)) ;;
    blocked) DOCTOR_BLOCKED=$((DOCTOR_BLOCKED + 1)) ;;
    *) status="warn"; DOCTOR_WARN=$((DOCTOR_WARN + 1)) ;;
  esac

  if [ "$DOCTOR_JSON" = "1" ]; then
    local jname jmsg
    jname=$(json_escape "$name")
    jmsg=$(json_escape "$message")
    DOCTOR_CHECKS+=("{\"name\":$jname,\"status\":\"$status\",\"message\":$jmsg}")
  else
    printf '  %-8s %s' "$(printf '%s' "$status" | tr '[:lower:]' '[:upper:]')" "$name"
    if [ -n "$message" ]; then printf ' — %s' "$message"; fi
    printf '\n'
  fi
}

check_command() {
  local cmd="$1" package_hint="${2:-$1}"
  if have_cmd "$cmd"; then
    local version=""
    version=$($cmd --version 2>/dev/null | head -1 || true)
    record_check ok "$cmd" "present${version:+: $version}"
  else
    record_check fixable "$cmd" "missing; install with doctor --fix (package: $package_hint)"
  fi
}

skill_installed() {
  local name="$1"
  local hhome="${HERMES_HOME:-$HOME/.hermes}"
  find "$hhome/skills" -path "*/$name/SKILL.md" -print -quit 2>/dev/null | grep -q . || \
    hermes skills list 2>/dev/null | grep -q "$name"
}

check_required_skill() {
  local name="$1"
  if ! have_cmd hermes; then
    record_check fixable "$name" "cannot check until Hermes is installed"
    return 0
  fi
  if skill_installed "$name"; then
    record_check ok "$name" "Hermes skill present"
  else
    record_check fixable "$name" "missing; install with doctor --fix"
  fi
}

plugin_present() {
  local plugin="$1"
  claude plugins list 2>/dev/null | grep -q "$plugin@"
}

check_optional_plugin() {
  local plugin="$1"
  if ! have_cmd claude; then
    record_check warn "$plugin" "cannot check until Claude Code is installed"
    return 0
  fi
  if plugin_present "$plugin"; then
    record_check ok "$plugin" "Claude plugin present"
  else
    record_check warn "$plugin" "optional plugin missing; install with doctor --fix --full"
  fi
}

check_runtime_link() {
  local runtime="${HERMES_HOME:-$HOME/.hermes}/skills/hercules"
  local expected="$REPO_ROOT/skills"
  if [ -L "$runtime" ]; then
    local resolved
    resolved=$(readlink -f "$runtime" || true)
    if [ "$resolved" = "$expected" ]; then
      record_check ok "runtime skills" "$runtime -> $expected"
    else
      record_check fixable "runtime skills" "symlink points to $resolved; doctor --fix can relink"
    fi
  elif [ -d "$runtime" ]; then
    record_check warn "runtime skills" "copy install exists at $runtime; symlink is recommended for development"
  else
    record_check fixable "runtime skills" "missing; doctor --fix can install/link"
  fi
}

check_validator() {
  local output=""
  if output=$(python3 "$VALIDATOR" --strict 2>&1); then
    record_check ok "validator" "strict validation passed"
  else
    record_check blocked "validator" "strict validation failed; run: python3 scripts/validate-skill-pack.py --strict"
  fi
}

check_repo() {
  record_check ok "repo" "$REPO_ROOT"
  if git status --short -uall | grep -q .; then
    record_check warn "worktree" "local changes present"
  else
    record_check ok "worktree" "clean"
  fi

  local count
  count=$(runtime_skill_count)
  if [ "$count" = "$EXPECTED_SKILL_COUNT" ]; then
    record_check ok "skill count" "$count runtime skills"
  else
    record_check warn "skill count" "expected $EXPECTED_SKILL_COUNT, found $count"
  fi
}

run_doctor_dashboard() {
  if [ "$DOCTOR_JSON" != "1" ]; then
    printf 'Hercules Doctor\n'
    printf '===============\n'
  fi

  if [ "$DOCTOR_JSON" != "1" ]; then section "System"; fi
  check_command git git
  check_command curl curl
  check_command bash bash
  check_command python3 python3
  check_command npm nodejs/npm

  if [ "$DOCTOR_JSON" != "1" ]; then section "Hermes"; fi
  check_command hermes hermes
  if [ -f "${HERMES_HOME:-$HOME/.hermes}/config.yaml" ]; then
    record_check ok "hermes config" "found"
  else
    record_check blocked "hermes config" "run: hermes setup"
  fi

  if [ "$DOCTOR_JSON" != "1" ]; then section "Hercules"; fi
  check_repo
  check_runtime_link
  check_validator

  if [ "$DOCTOR_JSON" != "1" ]; then section "Agent CLIs"; fi
  check_command claude "@anthropic-ai/claude-code"
  check_command codex "@openai/codex"
  if [ "$DOCTOR_JSON" != "1" ]; then
    printf '  INFO     provider access — not probed; credentials remain user-managed\n'
  fi

  if [ "$DOCTOR_JSON" != "1" ]; then section "Required Hermes skills"; fi
  check_required_skill subagent-driven-development
  check_required_skill writing-plans

  if [ "$DOCTOR_JSON" != "1" ]; then section "Optional Claude plugins"; fi
  check_optional_plugin superpowers
  check_optional_plugin oh-my-claudecode
  check_optional_plugin codex
  check_optional_plugin playwright
  check_optional_plugin context7
  check_optional_plugin pyright-lsp

  local overall="ready"
  if [ "$DOCTOR_BLOCKED" -gt 0 ]; then
    overall="blocked"
  elif [ "$DOCTOR_FIXABLE" -gt 0 ]; then
    overall="fixable"
  elif [ "$DOCTOR_WARN" -gt 0 ]; then
    overall="partial"
  fi

  if [ "$DOCTOR_JSON" = "1" ]; then
    printf '{'
    printf '"status":"%s",' "$overall"
    printf '"counts":{"ok":%s,"warn":%s,"fixable":%s,"blocked":%s},' "$DOCTOR_OK" "$DOCTOR_WARN" "$DOCTOR_FIXABLE" "$DOCTOR_BLOCKED"
    printf '"checks":['
    local first=1 item
    for item in "${DOCTOR_CHECKS[@]}"; do
      if [ "$first" = "0" ]; then printf ','; fi
      first=0
      printf '%s' "$item"
    done
    printf ']}\n'
  else
    section "Summary"
    printf 'status: %s\n' "$(printf '%s' "$overall" | tr '[:lower:]' '[:upper:]')"
    printf 'ok=%s warn=%s fixable=%s blocked=%s\n' "$DOCTOR_OK" "$DOCTOR_WARN" "$DOCTOR_FIXABLE" "$DOCTOR_BLOCKED"
    case "$overall" in
      ready)
        printf 'Next: hermes --tui, then load /skill hercules-agent-capability-preflight\n'
        ;;
      partial)
        printf 'Next: optional warnings remain. For full experience, run: scripts/hercules doctor --fix --full\n'
        ;;
      fixable)
        printf 'Next: run scripts/hercules doctor --fix\n'
        ;;
      blocked)
        printf 'Next: complete BLOCKED manual steps above, then rerun scripts/hercules doctor\n'
        ;;
    esac
  fi

  if [ "$DOCTOR_STRICT" = "1" ]; then
    [ "$DOCTOR_WARN" -eq 0 ] && [ "$DOCTOR_FIXABLE" -eq 0 ] && [ "$DOCTOR_BLOCKED" -eq 0 ]
  else
    [ "$DOCTOR_BLOCKED" -eq 0 ]
  fi
}

run_doctor() {
  local fix=0 full=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fix) fix=1 ;;
      --full) full=1 ;;
      --minimal) full=0 ;;
      --json) DOCTOR_JSON=1 ;;
      --strict) DOCTOR_STRICT=1 ;;
      -h|--help) usage; return 0 ;;
      *) printf 'Unknown doctor option: %s\n' "$1" >&2; return 2 ;;
    esac
    shift
  done

  if [ "$fix" = "1" ]; then
    if [ "$full" = "1" ]; then
      section "doctor --fix --full"
      "$INSTALL_SCRIPT" --full --yes
    else
      section "doctor --fix"
      "$INSTALL_SCRIPT" --minimal --yes
    fi
  fi

  run_doctor_dashboard
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    setup)
      shift
      run_setup "$@"
      ;;
    validate)
      shift
      if [ "$#" -ne 0 ]; then usage >&2; return 2; fi
      run_validate
      ;;
    bootstrap)
      shift
      run_bootstrap_check "$@"
      ;;
    status)
      shift
      if [ "$#" -ne 0 ]; then usage >&2; return 2; fi
      run_status
      ;;
    package)
      shift
      if [ "$#" -ne 0 ]; then usage >&2; return 2; fi
      run_package
      ;;
    doctor)
      shift
      run_doctor "$@"
      ;;
    *)
      printf 'Unknown command: %s\n\n' "$cmd" >&2
      usage >&2
      return 2
      ;;
  esac
}

main "$@"
